# ==============================================================================
# Backend — Local Development Environment Variables
# ==============================================================================
# Copy this file to .env (Backend/.env) for local development WITHOUT Docker.
# When using Docker Compose, the root .env is used and MONGODB_URI is auto-set.
# ==============================================================================

NODE_ENV=development
PORT=3000

# Local MongoDB (no auth for local dev convenience)
MONGODB_URI=mongodb://localhost:27017/easygenerator_dev

# JWT
JWT_SECRET=local_dev_jwt_secret_replace_me
JWT_EXPIRES_IN=7d

# CORS — allow the frontend origin
CORS_ORIGIN=http://localhost:5173
