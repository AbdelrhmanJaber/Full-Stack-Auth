# ==============================================================================
# Root — Docker Compose Environment Variables
# ==============================================================================
# Copy this file to .env at the root of the project before running docker-compose:
# cp .env.example .env
# ==============================================================================

# Backend Port Mapping (Host:Container)
PORT=3000

# MongoDB Configuration
MONGO_ROOT_USER=admin_user
MONGO_ROOT_PASSWORD=super_secure_mongodb_password_123
MONGO_DB_NAME=easygenerator_assessment

# JWT Configuration
JWT_SECRET=docker_compose_jwt_secret_replace_me_123456
JWT_EXPIRES_IN=7d
